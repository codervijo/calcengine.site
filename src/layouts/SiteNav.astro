---
import DarkModeToggle from '../components/DarkModeToggle';
---

<header class="sticky top-0 z-50 bg-white dark:bg-[#141414] border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-center h-14 gap-2">
      <a href="/" class="flex items-center gap-1.5 text-[#1565c0] dark:text-[#42a5f5] mr-1" aria-label="CalcEngine home">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M7 2h10a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zm0 2v4h10V4H7zm0 6v2h2v-2H7zm4 0v2h2v-2h-2zm4 0v2h2v-2h-2zm-8 4v2h2v-2H7zm4 0v2h2v-2h-2zm4 0v2h2v-2h-2zm-8 4v2h2v-2H7zm4 0v2h2v-2h-2zm4 0v2h2v-2h-2z"/>
        </svg>
      </a>
      <a href="/" class="font-bold text-gray-900 dark:text-gray-100 text-[1.05rem] flex-1 no-underline">
        CalcEngine
      </a>
      <span class="text-gray-400 dark:text-gray-600" style="color:inherit">
        <DarkModeToggle client:load />
      </span>
      <a href="/calculators" class="text-sm font-semibold text-gray-700 dark:text-gray-300 hover:text-[#1565c0] dark:hover:text-[#42a5f5] px-3 py-1.5 rounded transition-colors">
        All Calculators
      </a>
    </div>
  </div>
</header>
