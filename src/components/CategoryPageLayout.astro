---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../layouts/SiteNav.astro';
import SiteFooter from '../layouts/SiteFooter.astro';
import { getCalculatorsByCategory } from '../calculators/registry';
import { CATEGORY_LABELS, type CalculatorCategory } from '../calculators/registry/types';
import { buildBreadcrumbJsonLd } from '../seo/jsonLd';

interface Props {
  category: CalculatorCategory;
  title: string;
  description: string;
}

const { category, title, description } = Astro.props;
const BASE_URL = 'https://www.calcengine.site';
const calculators = getCalculatorsByCategory(category);
const categoryLabel = CATEGORY_LABELS[category];
const canonicalPath = `/calculators/${category}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: `${BASE_URL}${canonicalPath}`,
    inLanguage: 'en-US',
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: calculators.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: c.meta.title,
        url: `${BASE_URL}/calculators/${c.meta.slug}`,
      })),
    },
  },
  buildBreadcrumbJsonLd([
    { name: 'Home', url: BASE_URL },
    { name: 'Calculators', url: `${BASE_URL}/calculators` },
    { name: categoryLabel, url: `${BASE_URL}${canonicalPath}` },
  ]),
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonicalPath}
  jsonLd={jsonLd}
  ogImage={`${BASE_URL}/og/home.png`}
>
  <SiteNav />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">

    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-500 dark:text-gray-400 mb-6">
      <a href="/" class="hover:text-[#1565c0] dark:hover:text-[#42a5f5] transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href="/calculators" class="hover:text-[#1565c0] dark:hover:text-[#42a5f5] transition-colors">Calculators</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700 dark:text-gray-300">{categoryLabel}</span>
    </nav>

    <header class="mb-8">
      <span class="inline-block bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 text-xs font-semibold px-2.5 py-1 rounded-full mb-3">
        {categoryLabel}
      </span>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-3 leading-tight">
        {title}
      </h1>
      <p class="text-gray-500 dark:text-gray-400">{description}</p>
    </header>

    <!-- Calculator list -->
    <ul class="space-y-3 list-none">
      {calculators.map((c) => (
        <li>
          <a
            href={`/calculators/${c.meta.slug}`}
            class="flex justify-between items-start border border-gray-200 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-[#141414] hover:shadow-md dark:hover:border-gray-600 transition-all no-underline"
          >
            <div>
              <p class="font-semibold text-gray-900 dark:text-gray-100 mb-1">{c.meta.shortTitle}</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">{c.meta.description}</p>
            </div>
            <svg class="ml-4 mt-1 flex-shrink-0 text-gray-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800">
      <a href="/calculators" class="text-sm text-[#1565c0] dark:text-[#42a5f5] hover:underline">
        ← Browse all calculators
      </a>
    </div>

  </main>

  <SiteFooter />
</BaseLayout>
