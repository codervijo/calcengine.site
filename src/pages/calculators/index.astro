---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../layouts/SiteNav.astro';
import SiteFooter from '../../layouts/SiteFooter.astro';
import SearchableListIsland from '../../components/SearchableListIsland';
import { getAllCalculators } from '../../calculators/registry';
import { CATEGORY_LABELS } from '../../calculators/registry/types';
import { buildWebAppJsonLd } from '../../seo/jsonLd';

const BASE_URL = 'https://www.calcengine.site';
const calculators = getAllCalculators();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'All Free Engineering Calculators — CalcEngine',
  description: 'Browse all free engineering calculators for developers.',
  url: `${BASE_URL}/calculators`,
  inLanguage: 'en-US',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: calculators.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: c.meta.title,
      url: `${BASE_URL}/calculators/${c.meta.slug}`,
    })),
  },
};
---

<BaseLayout
  title="All Free Engineering Calculators — API, Data & Performance Tools"
  description="Browse all free engineering calculators for developers. Tools for API rate limits, OpenAI token costs, JSON sizing, Base64 encoding, and backend performance. No sign-up needed."
  canonical="/calculators"
  jsonLd={jsonLd}
  ogImage={`${BASE_URL}/og/home.png`}
>
  <SiteNav />

  <!-- Static header — visible to crawlers immediately -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-8 sm:pt-12 pb-2">
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-2">All Calculators</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-6">
      Browse and search our growing collection of engineering tools.
    </p>
  </div>

  <!-- Static list — rendered in HTML for crawlers and no-JS users.
       Hidden by SearchableListIsland on mount once React is ready. -->
  <ul id="static-calc-list" class="max-w-3xl mx-auto px-4 sm:px-6 pb-12 space-y-2 list-none">
    {calculators.map((c) => (
      <li>
        <a
          href={`/calculators/${c.meta.slug}`}
          class="flex justify-between items-start border border-gray-200 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-[#141414] hover:shadow-md dark:hover:border-gray-600 transition-all no-underline"
        >
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100 mb-1">{c.meta.shortTitle}</p>
            <p class="text-sm text-gray-500 dark:text-gray-400">{c.meta.description}</p>
          </div>
          <span class="ml-3 flex-shrink-0 text-xs font-semibold bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-2.5 py-1 rounded-full">
            {CATEGORY_LABELS[c.meta.category]}
          </span>
        </a>
      </li>
    ))}
  </ul>

  <!-- Interactive island — search + filter. Hidden until React mounts, then swaps with static list. -->
  <div id="react-calc-island" style="display:none" class="max-w-3xl mx-auto px-4 sm:px-6 pb-12">
    <SearchableListIsland client:only="react" />
  </div>

  <SiteFooter />
</BaseLayout>
