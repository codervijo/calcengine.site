---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../layouts/SiteNav.astro';
import SiteFooter from '../../layouts/SiteFooter.astro';
import CalculatorWidget from '../../components/CalculatorWidget';
import { getAllCalculators, getRelatedCalculators } from '../../calculators/registry';
import { CATEGORY_LABELS } from '../../calculators/registry/types';
import { buildFaqJsonLd, buildWebAppJsonLd, buildBreadcrumbJsonLd } from '../../seo/jsonLd';

export function getStaticPaths() {
  return getAllCalculators().map((c) => ({
    params: { slug: c.meta.slug },
    props: { meta: c.meta },
  }));
}

const { meta } = Astro.props;
const BASE_URL = 'https://www.calcengine.site';
const canonicalPath = `/calculators/${meta.slug}`;
const related = getRelatedCalculators(meta.relatedSlugs);

const jsonLd = [
  buildFaqJsonLd(meta.faq),
  buildWebAppJsonLd(meta.title, meta.description, `${BASE_URL}${canonicalPath}`, `${BASE_URL}/og/${meta.slug}.png`, meta.lastUpdated),
  buildBreadcrumbJsonLd([
    { name: 'Home', url: BASE_URL },
    { name: 'Calculators', url: `${BASE_URL}/calculators` },
    { name: meta.shortTitle, url: `${BASE_URL}${canonicalPath}` },
  ]),
];
---

<BaseLayout
  title={`${meta.title} — CalcEngine`}
  description={meta.description}
  canonical={canonicalPath}
  keywords={meta.keywords}
  jsonLd={jsonLd}
  ogImage={`${BASE_URL}/og/${meta.slug}.png`}
>
  <SiteNav />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-12">

    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-500 dark:text-gray-400 mb-5">
      <a href="/" class="hover:text-[#1565c0] dark:hover:text-[#42a5f5] transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href="/calculators" class="hover:text-[#1565c0] dark:hover:text-[#42a5f5] transition-colors">Calculators</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700 dark:text-gray-300">{meta.shortTitle}</span>
    </nav>

    <!-- Header: H1 + short tagline only — calculator must be above the fold -->
    <header class="mb-5">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-2 leading-tight">
        {meta.title}
      </h1>
      <span class="inline-block bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 text-xs font-semibold px-2.5 py-1 rounded-full mb-3">
        {CATEGORY_LABELS[meta.category]}
      </span>
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
        {meta.tagline ?? meta.description}
      </p>
    </header>

    <!-- Interactive calculator widget (React island) -->
    <section aria-label="Calculator" class="mb-3">
      <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#141414] shadow-sm p-4 sm:p-6">
        <CalculatorWidget slug={meta.slug} client:only="react" />
      </div>
    </section>

    <!-- Freshness signal + trust sentence -->
    <div class="mb-10">
      {meta.lastUpdated && (
        <p class="text-xs text-gray-400 dark:text-gray-500 text-right mb-1">
          Last updated: {meta.lastUpdated}
        </p>
      )}
      <p class="text-xs text-gray-400 dark:text-gray-500 text-right">
        This calculator is designed for real-world usage based on typical engineering scenarios and publicly available documentation.
      </p>
    </div>

    <!-- Intro / About (SEO body text — below the fold) -->
    <section aria-label="About this calculator" class="mb-8">
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed whitespace-pre-line">{meta.intro}</p>
    </section>

    <!-- How It Works -->
    <section aria-label={meta.howItWorksTitle ?? 'How It Works'} class="mb-8">
      <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">
        {meta.howItWorksTitle ?? 'How It Works'}
      </h2>
      {meta.howItWorksImage && (
        <img
          src={meta.howItWorksImage}
          alt={`${meta.shortTitle} — how it works diagram`}
          class="w-full rounded-lg border border-gray-200 dark:border-gray-800 mb-4"
          loading="lazy"
          decoding="async"
        />
      )}
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed whitespace-pre-line">{meta.howItWorks}</p>
    </section>

    <!-- Formula -->
    <section aria-label="Formula" class="mb-8">
      <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">Formula</h2>
      <pre class="bg-gray-100 dark:bg-gray-900 text-gray-800 dark:text-gray-200 p-4 rounded-lg overflow-x-auto text-sm font-mono leading-relaxed">{meta.formula}</pre>
    </section>

    <!-- Example(s) -->
    <section aria-label={meta.examplesTitle ?? 'Worked Example'} class="mb-8">
      <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">
        {meta.examplesTitle ?? 'Worked Example'}
      </h2>
      {meta.examples && meta.examples.length > 0 ? (
        <div class="space-y-3">
          {meta.examples.map((ex) => (
            <div class="rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50 p-4">
              <h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-2">{ex.title}</h3>
              <pre class="text-sm text-gray-600 dark:text-gray-400 font-mono whitespace-pre-wrap leading-relaxed">{ex.body}</pre>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-600 dark:text-gray-400 leading-relaxed whitespace-pre-line">{meta.example}</p>
      )}
    </section>

    <!-- Pricing table (optional) -->
    {meta.pricingTable && meta.pricingTable.length > 0 && (
      <section aria-label="Pricing by model" class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">
          {meta.pricingTableTitle ?? 'Pricing by Model'}
        </h2>
        <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-800">
          <table class="w-full text-sm text-left">
            <thead class="bg-gray-50 dark:bg-gray-900 text-gray-700 dark:text-gray-300 text-xs uppercase tracking-wide">
              <tr>
                <th class="px-4 py-3 font-semibold">Model</th>
                <th class="px-4 py-3 font-semibold">Input / 1M tokens</th>
                <th class="px-4 py-3 font-semibold">Output / 1M tokens</th>
                <th class="px-4 py-3 font-semibold hidden sm:table-cell">Notes</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
              {meta.pricingTable.map((row) => (
                <tr class="bg-white dark:bg-[#141414] hover:bg-gray-50 dark:hover:bg-gray-900/40 transition-colors">
                  <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100 whitespace-nowrap">{row.model}</td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400 font-mono">{row.inputPer1M}</td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-400 font-mono">{row.outputPer1M}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-gray-500 hidden sm:table-cell">{row.notes ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">Prices are approximate. Verify on your provider's pricing page before budgeting.</p>
      </section>
    )}

    <!-- Tips (optional) -->
    {meta.tips && meta.tips.length > 0 && (
      <section aria-label="Tips" class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">
          {meta.tipsTitle ?? 'Tips'}
        </h2>
        <ul class="space-y-2">
          {meta.tips.map((tip) => (
            <li class="flex gap-2 text-gray-600 dark:text-gray-400 leading-relaxed">
              <span class="text-blue-500 mt-1 shrink-0">›</span>
              <span>{tip}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Notes -->
    <section aria-label="Notes" class="mb-8">
      <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-3">Notes</h2>
      <ul class="space-y-1">
        <li class="flex gap-2 text-sm text-gray-500 dark:text-gray-400">
          <span class="text-blue-400 shrink-0">›</span>
          Results are estimates and may vary based on actual usage.
        </li>
        <li class="flex gap-2 text-sm text-gray-500 dark:text-gray-400">
          <span class="text-blue-400 shrink-0">›</span>
          Always validate against your production environment.
        </li>
      </ul>
    </section>

    <!-- FAQ — native <details> works without JS, visible to crawlers -->
    <section aria-label="Frequently Asked Questions" class="mb-10">
      <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-4">
        Frequently Asked Questions
      </h2>
      {meta.faq.map((item) => (
        <details class="border border-gray-200 dark:border-gray-800 rounded-lg mb-2 overflow-hidden">
          <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 dark:text-gray-100 hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors list-none flex justify-between items-center">
            {item.question}
            <span class="text-gray-400 text-lg ml-3 select-none">+</span>
          </summary>
          <div class="px-4 pb-4 pt-2 text-sm text-gray-600 dark:text-gray-400 leading-relaxed border-t border-gray-100 dark:border-gray-800 [&_a]:text-[#1565c0] dark:[&_a]:text-[#42a5f5] [&_a]:underline">
            <Fragment set:html={item.answer} />
          </div>
        </details>
      ))}
    </section>

    <!-- Related Calculators -->
    {related.length > 0 && (
      <aside aria-label="Related calculators">
        <h2 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-gray-100 mb-4">Related Calculators</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {related.map((r) => (
            <a href={`/calculators/${r.meta.slug}`} class="block border border-gray-200 dark:border-gray-800 rounded-xl p-4 bg-white dark:bg-[#141414] hover:shadow-md dark:hover:shadow-none dark:hover:border-gray-600 transition-all no-underline">
              <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1">{r.meta.shortTitle}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">{r.meta.description}</p>
            </a>
          ))}
        </div>
      </aside>
    )}

  </main>

  <SiteFooter />
</BaseLayout>
