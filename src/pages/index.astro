---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../layouts/SiteNav.astro';
import SiteFooter from '../layouts/SiteFooter.astro';
import { getAllCalculators } from '../calculators/registry';
import { CATEGORY_LABELS } from '../calculators/registry/types';
import { buildWebAppJsonLd, buildOrganizationJsonLd } from '../seo/jsonLd';

const BASE_URL = 'https://www.calcengine.site';
const calculators = getAllCalculators();

const jsonLd = [
  buildWebAppJsonLd(
    'CalcEngine',
    'Free engineering calculators for API costs, backend performance, and developer workflows.',
    BASE_URL,
    `${BASE_URL}/og/home.png`,
  ),
  buildOrganizationJsonLd(),
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'CalcEngine',
    url: BASE_URL,
    inLanguage: 'en-US',
  },
];

const features = [
  { title: 'Fast & Simple', desc: 'No sign-ups, no ads. Just instant results.' },
  { title: 'Built for Engineers', desc: 'Tools designed for real developer workflows.' },
  { title: 'Open Formulas', desc: 'Every calculator shows its formula and worked examples.' },
  { title: 'Always Free', desc: 'No paywalls. Use as much as you need.' },
];
---

<BaseLayout
  title="Engineering Calculators for Developers | API Cost, Tokens, Performance"
  description="Free engineering calculators for developers. Estimate OpenAI API cost, token usage, bandwidth, and backend performance instantly."
  canonical="/"
  jsonLd={jsonLd}
  ogImage={`${BASE_URL}/og/home.png`}
>
  <SiteNav />

  <!-- Hero -->
  <section aria-label="Hero" class="bg-[#1565c0] text-white py-16 sm:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 leading-tight">
        Engineering Calculators for Real Systems
      </h1>
      <p class="text-lg sm:text-xl opacity-90 mb-3 font-normal">
        Free tools for API costs, backend performance, and developer workflows.
      </p>
      <p class="text-base opacity-80 mb-8">
        CalcEngine provides fast, accurate engineering calculators for developers. Estimate API costs, token usage, and backend performance instantly.
      </p>
      <a href="/calculators" class="inline-flex items-center gap-2 bg-white text-[#1565c0] font-semibold px-8 py-3 rounded-lg hover:bg-gray-100 transition-colors no-underline text-base">
        Browse All Calculators
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Popular Calculators -->
  <section aria-label="Popular calculators" class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900 dark:text-gray-100 text-center mb-2">
      Popular Calculators
    </h2>
    <p class="text-gray-500 dark:text-gray-400 text-center mb-8">
      Start with these popular tools used by developers every day.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/calculators/openai-cost-calculator" class="block border border-gray-200 dark:border-gray-800 rounded-xl p-5 bg-white dark:bg-[#141414] hover:shadow-md dark:hover:border-gray-600 transition-all no-underline">
        <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1.5">OpenAI Cost Calculator</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Estimate OpenAI API costs by model, input tokens, and output tokens.</p>
      </a>
      <a href="/calculators/api-rate-limit-calculator" class="block border border-gray-200 dark:border-gray-800 rounded-xl p-5 bg-white dark:bg-[#141414] hover:shadow-md dark:hover:border-gray-600 transition-all no-underline">
        <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1.5">API Rate Limit Calculator</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Calculate total allowed requests over any time window given your rate limit.</p>
      </a>
      <a href="/calculators/json-size-calculator" class="block border border-gray-200 dark:border-gray-800 rounded-xl p-5 bg-white dark:bg-[#141414] hover:shadow-md dark:hover:border-gray-600 transition-all no-underline">
        <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1.5">JSON Size Calculator</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">Measure the exact byte size of any JSON payload in UTF-8.</p>
      </a>
      <a href="/calculators/base64-size-calculator" class="block border border-gray-200 dark:border-gray-800 rounded-xl p-5 bg-white dark:bg-[#141414] hover:shadow-md dark:hover:border-gray-600 transition-all no-underline">
        <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1.5">Base64 Size Calculator</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">See the exact Base64-encoded size and ~33% overhead from original bytes.</p>
      </a>
    </div>
  </section>

  <!-- Why CalcEngine -->
  <section aria-label="Why CalcEngine" class="bg-gray-50 dark:bg-[#0f0f0f] py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900 dark:text-gray-100 text-center mb-10">
        Why CalcEngine?
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {features.map((f) => (
          <div>
            <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-1">{f.title}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Category Sections -->
  <section aria-label="Calculator categories" class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900 dark:text-gray-100 text-center mb-10">Categories</h2>
    <div class="space-y-8">
      <div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">API Cost &amp; Token Calculators</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Estimate API costs and token usage across models.</p>
        <ul class="flex flex-wrap gap-3">
          <li><a href="/calculators/openai-cost-calculator" class="text-[#1565c0] dark:text-[#42a5f5] text-sm underline hover:opacity-80">OpenAI Cost Calculator</a></li>
          <li><a href="/calculators/api-rate-limit-calculator" class="text-[#1565c0] dark:text-[#42a5f5] text-sm underline hover:opacity-80">API Rate Limit Calculator</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Backend &amp; Performance Calculators</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Analyze rate limits, bandwidth, and system performance.</p>
        <ul class="flex flex-wrap gap-3">
          <li><a href="/calculators/api-rate-limit-calculator" class="text-[#1565c0] dark:text-[#42a5f5] text-sm underline hover:opacity-80">API Rate Limit Calculator</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Data &amp; Storage Calculators</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Calculate JSON size, payloads, and storage requirements.</p>
        <ul class="flex flex-wrap gap-3">
          <li><a href="/calculators/json-size-calculator" class="text-[#1565c0] dark:text-[#42a5f5] text-sm underline hover:opacity-80">JSON Size Calculator</a></li>
          <li><a href="/calculators/base64-size-calculator" class="text-[#1565c0] dark:text-[#42a5f5] text-sm underline hover:opacity-80">Base64 Size Calculator</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-wrap gap-2 justify-center mt-10 mb-10">
      {Object.entries(CATEGORY_LABELS).map(([, label]) => (
        <a href="/calculators" class="border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 text-sm px-4 py-1.5 rounded-full hover:border-[#1565c0] dark:hover:border-[#42a5f5] hover:text-[#1565c0] dark:hover:text-[#42a5f5] transition-colors no-underline">
          {label}
        </a>
      ))}
    </div>
    <div class="text-center">
      <a href="/calculators" class="inline-flex items-center gap-2 bg-[#1565c0] dark:bg-[#42a5f5] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[#0d47a1] dark:hover:bg-[#1565c0] transition-colors no-underline">
        View All Calculators
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- What you can calculate -->
  <section aria-label="What you can calculate" class="bg-gray-50 dark:bg-[#0f0f0f] py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900 dark:text-gray-100 mb-4">What you can calculate</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        CalcEngine helps developers estimate API costs, token usage, and backend performance. These tools are designed for real-world engineering scenarios, including AI applications, infrastructure planning, and performance tuning.
      </p>
      <p class="text-gray-600 dark:text-gray-400">
        Instead of using spreadsheets or manual calculations, users can quickly model usage, pricing, and scaling behavior using simple inputs.
      </p>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>
