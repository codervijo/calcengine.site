---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found | CalcEngine"
  description="The page you're looking for doesn't exist."
>
  <div style="display:flex;min-height:100vh;align-items:center;justify-content:center;font-family:Inter,sans-serif;">
    <div style="text-align:center;">
      <h1 style="font-size:3rem;font-weight:700;margin-bottom:1rem;">404</h1>
      <p style="font-size:1.25rem;color:#546e7a;margin-bottom:1.5rem;">Page not found</p>
      <a href="/" style="color:#1565c0;text-decoration:underline;">Return to Home</a>
    </div>
  </div>
</BaseLayout>
